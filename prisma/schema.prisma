// SymbioKnowledgeBase — Prisma Schema
// All tables have tenant_id with composite indexes for multi-tenant isolation.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

enum TeamspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum BlockType {
  DOCUMENT
  PARAGRAPH
  HEADING_1
  HEADING_2
  HEADING_3
  BULLETED_LIST
  NUMBERED_LIST
  TODO
  TOGGLE
  CODE
  QUOTE
  CALLOUT
  DIVIDER
  IMAGE
  BOOKMARK
  TABLE
  FILE
}

enum NotificationType {
  PAGE_MENTION
  PAGE_UPDATE
  AGENT_CREATED
  SYSTEM
}

enum FileStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum SpaceType {
  PRIVATE
  TEAM
  AGENT
}

// Discriminates first-class document pages from ordinary editable pages.
// Existing rows remain ordinary pages through the required PAGE default.
enum PageKind {
  PAGE
  DOCUMENT
}

enum ChangeType {
  MANUAL
  AUTO_SYNC
  PROPAGATED
  MACHINE_UPDATE
  AI_SUGGESTED
}

enum SourceType {
  URL
  PAGE
  MACHINE_PROTOCOL
}

// Kind of raw artifact captured in the immutable Source store (W81-A1).
enum SourceKind {
  DOCUMENT
  TRANSCRIPT
  NOTE
  EXPERIMENT_SYNC
  URL
}

enum SubscriptionBehavior {
  MIRROR
  NOTIFY
  SUGGEST
}

// ─── W81-A2: Claim / ClaimEvidence citation model ────────────────────
// Lifecycle of a wiki assertion. W81-B1 flips ACTIVE → SUPERSEDED when a
// contradiction supersedes it; this story only ever writes ACTIVE.
enum ClaimStatus {
  ACTIVE
  SUPERSEDED
}

// W81-B1: precision of a Source's / Claim's event date. A bare `DateTime` cannot
// carry "~approximately June 2026" — the temporal-safety rule treats UNKNOWN as
// "never auto-supersede" and APPROX conservatively (defer to C1 on close calls).
enum DatePrecision {
  EXACT
  APPROX
  UNKNOWN
}

// The evidence relation between a Claim and a SourceChunk. A SUPPORTS edge
// attaches to the NEW body claim; a CONTRADICTS edge attaches to the EXISTING
// claim it refutes (the W81-B1 trigger signal).
enum EvidenceRelation {
  SUPPORTS
  CONTRADICTS
}

// The machine-checkable trust signal produced by the quote-validation gate.
// UNVERIFIED is never rendered as a trusted receipt (W81-A3) and never trusted
// by contradiction logic (W81-B1).
enum EvidenceValidation {
  EXACT
  FUZZY
  UNVERIFIED
}

// Durable async-job status for the enrichment+citation pipeline (SKB has no
// in-process job infra that survives a restart, so this is a real table).
enum EnrichJobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

// ─── W81-C1: Triage worker (staleness / dedup / contradiction / tagging) ──
// The cheap-tier "sleeping updater" — a bounded, externally-scheduled sweep that
// FLAGS work (never rewrites page bodies) and escalates only genuine hard cases.

// Which of the four passes a keyset cursor / run belongs to. A single UUID cursor
// is WRONG (Codex R1): the four passes traverse different domains, so each keeps
// its own keyset watermark.
enum TriagePass {
  STALENESS // (a) deterministic scoped-key collision — NO LLM
  TAGGING // (b) source→concept relevance — local 7B
  DEDUP // (c) embedding near-duplicate — deterministic vector search
  CONTRADICTION // (d) embedding-retrieved claim pairs — local 7B yes/no/maybe
}

// The kind of finding a pass surfaces.
enum TriageKind {
  STALE // (a) a (subject,relation) collision the page hasn't reflected
  SOURCE_TAGGED // (b) a new source is relevant to a concept page (hand-off list)
  POSSIBLE_DUPLICATE // (c) two concept pages are near-duplicates
  CONTRADICTION_CANDIDATE // (d) two claims may disagree (advisory, not resolved)
}

// Finding lifecycle. A global unique fingerprint would P2002-drop a recurrence
// after DISMISS/RESOLVE, so uniqueness is a PARTIAL index over the non-terminal
// states only (OPEN|ESCALATED|DEFERRED) — declared in the migration, not here.
// DEFERRED = the Ollama-down state (bounded backoff + nextAttemptAt + max retries).
enum TriageStatus {
  OPEN
  ESCALATED
  DEFERRED
  DISMISSED
  RESOLVED
}

// A bounded triage run's terminal state.
enum TriageRunStatus {
  RUNNING
  COMPLETED
  BUDGET_EXHAUSTED
  FAILED
}

enum Permission {
  FULL_ACCESS
  CAN_EDIT
  CAN_COMMENT
  CAN_VIEW
}

enum GeneralAccess {
  INVITED_ONLY
  ANYONE_WITH_LINK
}

// ─── Tenants ─────────────────────────────────────────────────────────

model Tenant {
  id           String   @id @default(uuid())
  name         String
  storageQuota BigInt   @default(5368709120) @map("storage_quota")
  storageUsed  BigInt   @default(0) @map("storage_used")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  users                 User[]
  members               TenantMember[]
  pages                 Page[]
  blocks                Block[]
  pageLinks             PageLink[]
  apiKeys               ApiKey[]
  databases             Database[]
  dbRows                DbRow[]
  teamspaces            Teamspace[]
  publicShareLinks      PublicShareLink[]
  presenceRecords       PagePresence[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  documentVersions      DocumentVersion[]
  documentSubscriptions DocumentSubscription[]
  fileAttachments       FileAttachment[]
  pageFavorites         PageFavorite[]
  pageShares            PageShare[]
  sweepSessions         SweepSession[]
  googleDriveConnections GoogleDriveConnection[]
  oauthStates            OAuthState[]
  pageSyncSectionStates  PageSyncSectionState[]
  ingestLedgerEntries   IngestLedgerEntry[]
  sources               Source[]
  claims                Claim[]
  claimEvidence         ClaimEvidence[]
  claimSupersessions    ClaimSupersession[]
  enrichJobs            EnrichJob[]
  triageRuns            TriageRun[]
  triageFindings        TriageFinding[]
  triageCursors         TriageCursor[]
  sourceRelevances      SourceRelevance[]
  triageDigests         TriageDigest[]
  aokSites              AokSite[]
  aokSpaces             AokSpace[]
  aokAssets             AokAsset[]
  aokAnchors            AokAnchor[]
  aokKnowledge          AokKnowledge[]
  aokVisits             AokVisit[]
  aokCountLines         AokCountLine[]

  @@map("tenants")
}

// ─── Tenant Members (workspace memberships) ─────────────────────────

model TenantMember {
  id       String   @id @default(uuid())
  userId   String   @map("user_id") // Supabase auth user ID
  tenantId String   @map("tenant_id")
  role     String   @default("owner") // "owner" | "admin" | "member"
  joinedAt DateTime @default(now()) @map("joined_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId], map: "uq_tenant_members_user_tenant")
  @@index([userId], map: "idx_tenant_members_user_id")
  @@map("tenant_members")
}

// ─── Users ───────────────────────────────────────────────────────────

model User {
  id            String    @id // Supabase auth.users.id (UUID) — no @default for Supabase-managed IDs
  tenantId      String    @map("tenant_id")
  email         String
  passwordHash  String?   @map("password_hash") // Deprecated — managed by Supabase Auth
  role          Role      @default(USER)
  name          String?
  avatarUrl     String?   @map("avatar_url")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deactivatedAt DateTime? @map("deactivated_at")

  // Relations
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiKeys               ApiKey[]
  teamspaceMemberships  TeamspaceMember[]
  createdShareLinks     PublicShareLink[]
  presenceRecords       PagePresence[]
  receivedNotifications Notification[]    @relation("NotificationRecipient")
  sentNotifications     Notification[]    @relation("NotificationSource")
  auditLogs             AuditLog[]
  fileAttachments       FileAttachment[]
  googleDriveConnections GoogleDriveConnection[]
  oauthStates            OAuthState[]

  // Indexes
  @@unique([tenantId, email], map: "uq_users_email_tenant_id")
  @@index([tenantId, id], map: "idx_users_tenant_id_id")
  @@index([tenantId], map: "idx_users_tenant_id")
  @@map("users")
}

// ─── Pages ───────────────────────────────────────────────────────────

model Page {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  externalId       String?       @map("external_id")
  parentId         String?       @map("parent_id")
  teamspaceId      String?       @map("teamspace_id")
  title            String        @default("Untitled")
  icon             String?
  coverUrl         String?       @map("cover_url")
  position         Int           @default(0)
  spaceType        SpaceType     @default(PRIVATE) @map("space_type")
  generalAccess    GeneralAccess @default(INVITED_ONLY) @map("general_access")
  kind             PageKind      @default(PAGE)
  sourceUrl        String?       @map("source_url")
  docSource        String?       @map("doc_source")
  oneLiner         String?       @map("one_liner")
  summary          String?       @map("summary")
  // Additive, nullable JSON bag for structured page metadata (a71-13 OKF
  // enrichment: concept type/tags/aliases/first_seen/last_seen, and the
  // experiments-index regeneration stamp). INVARIANT: every writer MUST patch
  // its OWN subkey via `jsonb_set`/`||` in a single `$executeRaw` UPDATE — never
  // a full-column Prisma JSON write — so concurrent writers to different subkeys
  // never clobber each other. See docs/stories/2026-07-10-W81-EPIC-INDEX.md.
  properties       Json?         @map("properties")
  summaryUpdatedAt DateTime?     @map("summary_updated_at")
  lastAgentVisitAt DateTime?     @map("last_agent_visit_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")
  deletedBy        String?       @map("deleted_by")

  // Relations
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent                Page?                  @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children              Page[]                 @relation("PageHierarchy")
  teamspace             Teamspace?             @relation(fields: [teamspaceId], references: [id], onDelete: SetNull)
  blocks                Block[]
  sourceLinks           PageLink[]             @relation("SourcePage")
  targetLinks           PageLink[]             @relation("TargetPage")
  databases             Database[]
  dbRows                DbRow[]
  publicShareLinks      PublicShareLink[]
  presenceRecords       PagePresence[]
  notifications         Notification[]
  documentVersions      DocumentVersion[]
  documentSubscriptions DocumentSubscription[]
  fileAttachments       FileAttachment[]
  favorites             PageFavorite[]
  shares                PageShare[]
  claims                Claim[]
  syncSectionStates     PageSyncSectionState[]

  // Indexes
  @@unique([tenantId, externalId], map: "uq_pages_tenant_id_external_id")
  @@index([tenantId, id], map: "idx_pages_tenant_id_id")
  @@index([tenantId], map: "idx_pages_tenant_id")
  @@index([tenantId, parentId], map: "idx_pages_tenant_id_parent_id")
  @@index([tenantId, teamspaceId], map: "idx_pages_tenant_id_teamspace_id")
  @@index([tenantId, spaceType], map: "idx_pages_tenant_id_space_type")
  @@index([tenantId, deletedAt], map: "idx_pages_tenant_id_deleted_at")
  @@index([tenantId, kind], map: "idx_pages_tenant_id_kind")
  @@map("pages")
}

// ─── Blocks ──────────────────────────────────────────────────────────

model Block {
  id           String                   @id @default(uuid())
  pageId       String                   @map("page_id")
  tenantId     String                   @map("tenant_id")
  type         BlockType                @default(PARAGRAPH)
  content      Json                     @default("{}")
  position     Int                      @default(0)
  version      Int                      @default(0)
  plainText    String                   @default("") @map("plain_text")
  searchVector Unsupported("tsvector")? @map("search_vector")
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")
  deletedAt    DateTime?                @map("deleted_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([tenantId, id], map: "idx_blocks_tenant_id_id")
  @@index([tenantId], map: "idx_blocks_tenant_id")
  @@index([pageId], map: "idx_blocks_page_id")
  @@index([tenantId, pageId], map: "idx_blocks_tenant_id_page_id")
  @@map("blocks")
}

// Tracks the last content update applied to each externally-owned section of
// an experiment page, allowing duplicate and out-of-order sync events to no-op.
model PageSyncSectionState {
  id                String   @id @default(uuid())
  pageId            String   @map("page_id")
  tenantId          String   @map("tenant_id")
  sectionKey        String   @map("section_key")
  lastAppliedAt     DateTime @map("last_applied_at")
  lastCorrelationId String?  @map("last_correlation_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, sectionKey], map: "uq_page_sync_section_state_page_section")
  @@index([tenantId], map: "idx_page_sync_section_state_tenant_id")
  @@index([tenantId, pageId], map: "idx_page_sync_section_state_tenant_id_page_id")
  @@map("page_sync_section_state")
}

// ─── Page Links ──────────────────────────────────────────────────────

model PageLink {
  id           String   @id @default(uuid())
  sourcePageId String   @map("source_page_id")
  targetPageId String   @map("target_page_id")
  tenantId     String   @map("tenant_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourcePage Page   @relation("SourcePage", fields: [sourcePageId], references: [id], onDelete: Cascade)
  targetPage Page   @relation("TargetPage", fields: [targetPageId], references: [id], onDelete: Cascade)

  // Indexes
  @@unique([sourcePageId, targetPageId], map: "uq_page_links_source_target")
  @@index([tenantId, id], map: "idx_page_links_tenant_id_id")
  @@index([tenantId], map: "idx_page_links_tenant_id")
  @@index([tenantId, sourcePageId], map: "idx_page_links_tenant_id_source")
  @@index([tenantId, targetPageId], map: "idx_page_links_tenant_id_target")
  @@map("page_links")
}

// ─── API Keys ────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tenantId   String    @map("tenant_id")
  keyHash    String    @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  name       String
  scopes     String[]  @default(["read", "write"])
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  // Indexes
  @@index([tenantId, id], map: "idx_api_keys_tenant_id_id")
  @@index([tenantId], map: "idx_api_keys_tenant_id")
  @@index([keyHash], map: "idx_api_keys_key_hash")
  @@map("api_keys")
}

// ─── Databases (Notion-style typed tables) ───────────────────────────

model Database {
  id          String   @id @default(uuid())
  pageId      String   @map("page_id")
  tenantId    String   @map("tenant_id")
  schema      Json     @default("{}") @map("schema")
  defaultView String   @default("table") @map("default_view")
  viewConfig  Json?    @map("view_config")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  page   Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  rows   DbRow[]

  // Indexes
  @@index([tenantId, id], map: "idx_databases_tenant_id_id")
  @@index([tenantId], map: "idx_databases_tenant_id")
  @@index([pageId], map: "idx_databases_page_id")
  @@map("databases")
}

// ─── Database Rows ───────────────────────────────────────────────────

model DbRow {
  id         String   @id @default(uuid())
  databaseId String   @map("database_id")
  pageId     String?  @map("page_id")
  tenantId   String   @map("tenant_id")
  properties Json     @default("{}") @map("properties")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  page     Page?    @relation(fields: [pageId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([tenantId, id], map: "idx_db_rows_tenant_id_id")
  @@index([tenantId], map: "idx_db_rows_tenant_id")
  @@index([databaseId], map: "idx_db_rows_database_id")
  @@index([tenantId, databaseId], map: "idx_db_rows_tenant_id_database_id")
  @@map("db_rows")
}

// ─── Teamspaces ─────────────────────────────────────────────────

model Teamspace {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String?  @map("slug")
  description String?  @map("description")
  icon        String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members TeamspaceMember[]
  pages   Page[]

  // Indexes
  @@unique([tenantId, name], map: "uq_teamspaces_tenant_name")
  @@unique([tenantId, slug], map: "uq_teamspaces_tenant_slug")
  @@index([tenantId], map: "idx_teamspaces_tenant_id")
  @@map("teamspaces")
}

model TeamspaceMember {
  id          String        @id @default(uuid())
  teamspaceId String        @map("teamspace_id")
  userId      String        @map("user_id")
  role        TeamspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now()) @map("created_at")

  // Relations
  teamspace Teamspace @relation(fields: [teamspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@unique([teamspaceId, userId], map: "uq_teamspace_members_teamspace_user")
  @@index([teamspaceId, role], map: "idx_teamspace_members_teamspace_role")
  @@map("teamspace_members")
}

// ─── Public Share Links ─────────────────────────────────────────

model PublicShareLink {
  id            String    @id @default(uuid())
  pageId        String    @map("page_id")
  tenantId      String    @map("tenant_id")
  token         String    @unique
  createdBy     String    @map("created_by")
  allowIndexing Boolean   @default(false) @map("allow_indexing")
  publishedAt   DateTime? @map("published_at")
  expiresAt     DateTime  @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  page          Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdByUser User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  // Indexes
  @@index([token], map: "idx_public_share_links_token")
  @@index([pageId], map: "idx_public_share_links_page_id")
  @@map("public_share_links")
}

// ─── Page Presence ──────────────────────────────────────────────

model PagePresence {
  id            String   @id @default(uuid())
  pageId        String   @map("page_id")
  userId        String   @map("user_id")
  tenantId      String   @map("tenant_id")
  lastHeartbeat DateTime @default(now()) @map("last_heartbeat")
  isEditing     Boolean  @default(false) @map("is_editing")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@unique([pageId, userId], map: "uq_page_presence_page_user")
  @@index([pageId], map: "idx_page_presence_page_id")
  @@index([lastHeartbeat], map: "idx_page_presence_last_heartbeat")
  @@map("page_presence")
}

// ─── Notifications ───────────────────────────────────────────────────

model Notification {
  id           String           @id @default(uuid())
  tenantId     String           @map("tenant_id")
  userId       String           @map("user_id")
  type         NotificationType
  title        String
  body         String?
  pageId       String?          @map("page_id")
  sourceUserId String?          @map("source_user_id")
  read         Boolean          @default(false)
  createdAt    DateTime         @default(now()) @map("created_at")

  // Relations
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User   @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  page       Page?  @relation(fields: [pageId], references: [id], onDelete: SetNull)
  sourceUser User?  @relation("NotificationSource", fields: [sourceUserId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([tenantId, userId, createdAt], map: "idx_notifications_user_created")
  @@index([tenantId, userId, read], map: "idx_notifications_user_read")
  @@map("notifications")
}

// ─── Document Versions ──────────────────────────────────────────────

model DocumentVersion {
  id           String     @id @default(uuid())
  pageId       String     @map("page_id")
  tenantId     String     @map("tenant_id")
  version      Int
  content      Json
  plainText    String     @map("plain_text")
  changeType   ChangeType @map("change_type")
  changeSource String?    @map("change_source")
  changeNotes  String?    @map("change_notes")
  diffFromPrev Json?      @map("diff_from_prev")
  createdAt    DateTime   @default(now()) @map("created_at")

  // Relations
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  page   Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  claims Claim[]

  // Indexes
  @@unique([pageId, version])
  @@index([pageId])
  @@index([tenantId, pageId])
  @@map("document_versions")
}

// ─── Ingest Ledger (OKF enrichment idempotency) ──────────────────────
//
// Records every raw-text ingestion processed by the enrichment engine
// (`/api/agent/pages/enrich`), keyed by the sha256 of the raw input. A
// byte-identical re-submission for the same tenant short-circuits before any
// LLM call. The unique key is composite `(tenant_id, content_hash)`, so the
// same hash may exist independently for different tenants (no cross-tenant
// P2002); a genuine same-tenant re-submit collapses to an idempotent no-op.
model IngestLedgerEntry {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  contentHash String   @map("content_hash")
  sourceName  String   @map("source_name")
  planSummary String?  @map("plan_summary")
  actionCount Int      @default(0) @map("action_count")
  ingestedAt  DateTime @default(now()) @map("ingested_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Indexes
  @@unique([tenantId, contentHash], map: "uq_ingest_ledger_tenant_content_hash")
  @@index([tenantId], map: "idx_ingest_ledger_tenant_id")
  @@map("ingest_ledger_entries")
}

// ─── Immutable Source + SourceChunk store (W81-A1) ───────────────────
//
// Append-only raw-text corpus that wiki claims cite back to. Immutability is
// enforced by DB triggers (see the migration), NOT Prisma middleware (Prisma 7
// removed `$use`). The service exposes create + read only — there is no
// update/delete path. Corrections = ingest a NEW Source, superseded at the wiki
// layer (W81-B1). Distinct from `FileAttachment` (raw bytes) — this is the
// parsed, chunked, hashed text.

// One row per ingested raw artifact. `rawText` is stored VERBATIM (no
// normalization) so chunk code-point offsets into it are always valid.
model Source {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")
  kind           SourceKind
  title          String
  contentSha256  String        @map("content_sha256")
  chunkerVersion String        @map("chunker_version")
  rawText        String        @map("raw_text")
  ingestedAt     DateTime      @default(now()) @map("ingested_at")
  ingestedBy     String?       @map("ingested_by")
  correlationId  String?       @map("correlation_id")
  // W81-B1: when the artifact's content is dated in the world (parsed from the
  // filename/doc metadata), distinct from `ingestedAt` (when the system saw it).
  // `Claim.tValid` derives from this → else the claim's `txCreated`. Null +
  // UNKNOWN precision means "no world date" and blocks auto-supersession.
  eventDate      DateTime?     @map("event_date")
  datePrecision  DatePrecision @default(UNKNOWN) @map("date_precision")

  // Relations
  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks  SourceChunk[]
  origins SourceOrigin[]

  // Dedup key: identical text re-chunked under a NEW chunkerVersion mints a new
  // Source (Codex R1). Same text + different provenance is preserved as multiple
  // SourceOrigin rows on ONE Source, never collapsed.
  @@unique([tenantId, contentSha256, chunkerVersion], map: "uq_sources_tenant_sha_chunker")
  // REQUIRED by the composite FK below: SourceChunk/SourceOrigin reference
  // Source(tenant_id, id); Postgres needs an explicit unique on the exact
  // referenced columns or `prisma validate` fails (GLM R2).
  @@unique([tenantId, id], map: "uq_sources_tenant_id")
  @@index([tenantId], map: "idx_sources_tenant_id")
  @@map("sources")
}

// Deterministic, append-only segmentation of Source.rawText — the citation
// anchor. `charStart`/`charEnd` are half-open Unicode CODE-POINT offsets;
// `text` === rawText's [charStart, charEnd) code-point slice. `textSha256` is a
// content fingerprint (repeated paragraphs/overlap legitimately collide), NOT an
// identity — identity is (sourceId, chunkIndex).
model SourceChunk {
  id         String                       @id @default(uuid())
  tenantId   String                       @map("tenant_id")
  sourceId   String                       @map("source_id")
  chunkIndex Int                          @map("chunk_index")
  charStart  Int                          @map("char_start")
  charEnd    Int                          @map("char_end")
  text       String
  textSha256 String                       @map("text_sha256")
  // pgvector; nullable until the durable embedding backfill sweep fills it. The
  // typed client omits this column — embedding writes go through raw SQL.
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now()) @map("created_at")

  // Tenant-consistent composite FK (no RLS): a chunk can only ever hang off a
  // Source of the SAME tenant.
  source   Source          @relation(fields: [tenantId, sourceId], references: [tenantId, id], onDelete: Cascade)
  evidence ClaimEvidence[]

  @@unique([sourceId, chunkIndex], map: "uq_source_chunks_source_chunk_index")
  @@index([tenantId, sourceId], map: "idx_source_chunks_tenant_source")
  @@map("source_chunks")
}

// One Source (immutable content) ← N ingestion occurrences. Same text ingested
// from different places (a re-upload, a synced experiment) records a distinct
// provenance row instead of collapsing (Codex R1).
model SourceOrigin {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  sourceId   String     @map("source_id")
  originRef  String?    @map("origin_ref")
  kind       SourceKind
  title      String
  ingestedAt DateTime   @default(now()) @map("ingested_at")
  ingestedBy String?    @map("ingested_by")

  source Source @relation(fields: [tenantId, sourceId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, sourceId, originRef], map: "uq_source_origins_tenant_source_ref")
  @@index([tenantId, sourceId], map: "idx_source_origins_tenant_source")
  @@map("source_origins")
}

// ─── W81-A2: Claim + ClaimEvidence citation layer ────────────────────
//
// A `Claim` is one atomic assertion on a wiki/concept page, indexed in parallel
// to the page body (the body is Tiptap JSON in `Block.content`; there is no
// persisted markdown string to hold char offsets against). Body anchoring is by
// `anchorTextSha` (= sha256 of the normalized claim text) re-matched against
// `Block.plainText` — a durable text anchor, not a fragile char offset. Each
// Claim pins the `DocumentVersion` it was authored against (a real FK,
// onDelete: Restrict) so decomposition drift is a per-version snapshot and the
// version pruner must skip claim-referenced versions.
model Claim {
  id                  String        @id @default(uuid())
  tenantId            String        @map("tenant_id")
  pageId              String        @map("page_id")
  text                String
  // Deterministic identity: sha256(pageId + normalize(text) + documentVersionId).
  // Retries collapse on @@unique([tenantId, claimKey]) instead of minting new ids.
  claimKey            String        @map("claim_key")
  // sha256(normalize(text)); the body anchor is a TEXT re-match into
  // Block.plainText, NOT a char offset into ephemeral markdown.
  anchorTextSha       String        @map("anchor_text_sha")
  documentVersionId   String        @map("document_version_id")
  status              ClaimStatus   @default(ACTIVE)
  // ─── W81-B1 bitemporal timestamps ────────────────────────────────────
  // tValid   : when the asserted fact became TRUE in the world (from
  //            Source.eventDate → else txCreated). DB-defaulted to now() so
  //            legacy/unknown-date claims coincide with their ingest time.
  // tInvalid : when it stopped being true (null = still valid; a FUTURE value
  //            means "effective until then" — status stays ACTIVE until it passes).
  // txCreated: when the SYSTEM recorded it (DB `now()`, not an app clock).
  // txExpired: when the system marked it superseded (null = live).
  tValid              DateTime      @default(now()) @map("t_valid")
  tInvalid            DateTime?     @map("t_invalid")
  txCreated           DateTime      @default(now()) @map("tx_created")
  txExpired           DateTime?     @map("tx_expired")
  // Precision carried from the source so the temporal rule treats UNKNOWN/APPROX
  // dates conservatively (UNKNOWN never auto-supersedes).
  datePrecision       DatePrecision @default(UNKNOWN) @map("date_precision")
  supersededByClaimId String?       @map("superseded_by_claim_id")
  supersedeReason     String?       @map("supersede_reason")
  createdAt           DateTime      @default(now()) @map("created_at")

  // Relations
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // onDelete: NoAction — a claim must never be cascade-deleted when its page is
  // purged (that would erase belief history — W81-B1 invariant). NO ACTION blocks
  // a direct page delete while claims reference it (a hard-purge must archive
  // claims first), while still letting a whole-tenant Cascade clean up (claims are
  // removed via their own tenant FK before the end-of-statement check). See story
  // "Lifecycle: duplicate / restore / purge".
  page               Page                @relation(fields: [pageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  // onDelete: Restrict — the per-version snapshot a claim pins must never dangle;
  // pruneOldVersions() explicitly skips versions referenced here.
  documentVersion    DocumentVersion     @relation(fields: [documentVersionId], references: [id], onDelete: Restrict)
  evidence           ClaimEvidence[]
  // Self-relation: the newer claim that superseded this one (belief chain).
  supersededBy       Claim?              @relation("ClaimSupersedes", fields: [supersededByClaimId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supersedes         Claim[]             @relation("ClaimSupersedes")
  supersessionsAsOld ClaimSupersession[] @relation("SupersessionOld")
  supersessionsAsNew ClaimSupersession[] @relation("SupersessionNew")

  @@unique([tenantId, claimKey], map: "uq_claims_tenant_claim_key")
  @@index([tenantId, pageId], map: "idx_claims_tenant_page")
  @@index([tenantId, status], map: "idx_claims_tenant_status")
  // Temporal read path: active-at-time queries filter (tenant, status, tValid).
  @@index([tenantId, status, tValid], map: "idx_claims_tenant_status_tvalid")
  // Supersession-chain traversal.
  @@index([supersededByClaimId], map: "idx_claims_superseded_by")
  @@index([documentVersionId], map: "idx_claims_document_version")
  @@map("claims")
}

// W81-B1: an append-only audit of every applied supersession — which older claim
// was invalidated by which newer one, why, and the valid-time set. The unique key
// makes re-runs idempotent (a retried ingest can't double-write the same edge).
// oldClaim/newClaim FKs are NoAction (claims are never deleted; tenant Cascade
// cleans these rows via their own tenant FK).
model ClaimSupersession {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  oldClaimId      String   @map("old_claim_id")
  newClaimId      String   @map("new_claim_id")
  reason          String
  // The valid-time written onto the older claim's tInvalid.
  tInvalidApplied DateTime @map("t_invalid_applied")
  // false = future-effective (older claim kept ACTIVE, flipped later); true =
  // present-effective (older claim marked SUPERSEDED now).
  effectiveNow    Boolean  @default(true) @map("effective_now")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  oldClaim Claim  @relation("SupersessionOld", fields: [oldClaimId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  newClaim Claim  @relation("SupersessionNew", fields: [newClaimId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([oldClaimId, newClaimId, reason], map: "uq_claim_supersession_old_new_reason")
  @@index([tenantId, oldClaimId], map: "idx_claim_supersession_tenant_old")
  @@index([tenantId, newClaimId], map: "idx_claim_supersession_tenant_new")
  @@map("claim_supersessions")
}

// One evidence edge: a Claim ↔ a SourceChunk it cites, tagged with the
// quote-validation gate's verdict. `matchedText` is the CANONICAL source
// substring actually found in `SourceChunk.text` (never the model's paraphrase);
// `quoteSha256` hashes THAT for EXACT/FUZZY, and uses a deterministic sentinel
// for UNVERIFIED so the retry-idempotency unique index still dedupes (a NULL
// would be distinct in Postgres and defeat it). `chunkCharStart/End` are
// WITHIN-chunk code-point offsets (a different coordinate space from A1's
// within-rawText offsets).
model ClaimEvidence {
  id              String             @id @default(uuid())
  tenantId        String             @map("tenant_id")
  claimId         String             @map("claim_id")
  chunkId         String             @map("chunk_id")
  matchedText     String?            @map("matched_text")
  quoteSha256     String             @map("quote_sha256")
  chunkCharStart  Int?               @map("chunk_char_start")
  chunkCharEnd    Int?               @map("chunk_char_end")
  relation        EvidenceRelation
  validationState EvidenceValidation @map("validation_state")
  confidence      Float              @default(0)
  createdAt       DateTime           @default(now()) @map("created_at")

  // Relations
  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  claim  Claim       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  chunk  SourceChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  // Idempotent retry key; quoteSha256 is NOT NULL (sentinel for UNVERIFIED).
  @@unique([claimId, chunkId, quoteSha256], map: "uq_claim_evidence_claim_chunk_quote")
  @@index([tenantId, claimId], map: "idx_claim_evidence_tenant_claim")
  @@index([tenantId, chunkId], map: "idx_claim_evidence_tenant_chunk")
  @@map("claim_evidence")
}

// Durable async-job row for POST /api/agent/pages/enrich real runs. SKB has no
// restart-surviving in-process queue, so the job (and its result) live in the DB;
// GET /api/agent/pages/enrich/[jobId] reads this row.
model EnrichJob {
  id        String          @id @default(uuid())
  tenantId  String          @map("tenant_id")
  status    EnrichJobStatus @default(QUEUED)
  request   Json
  result    Json?
  error     String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status], map: "idx_enrich_jobs_tenant_status")
  @@index([status, createdAt], map: "idx_enrich_jobs_status_created")
  @@map("enrich_jobs")
}

// ─── Document Subscriptions ─────────────────────────────────────────

model DocumentSubscription {
  id               String               @id @default(uuid())
  tenantId         String               @map("tenant_id")
  subscriberPageId String               @map("subscriber_page_id")
  sourceType       SourceType           @map("source_type")
  sourcePageId     String?              @map("source_page_id")
  sourceUrl        String?              @map("source_url")
  behavior         SubscriptionBehavior @default(NOTIFY)
  lastSyncedAt     DateTime?            @map("last_synced_at")
  lastSyncVersion  Int?                 @map("last_sync_version")
  isActive         Boolean              @default(true) @map("is_active")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriberPage Page   @relation(fields: [subscriberPageId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([tenantId, subscriberPageId])
  @@index([sourcePageId])
  @@map("document_subscriptions")
}

// ─── File Attachments ───────────────────────────────────────────────

model FileAttachment {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  userId      String     @map("user_id")
  pageId      String?    @map("page_id")
  fileName    String     @map("file_name")
  fileSize    BigInt     @map("file_size")
  mimeType    String     @map("mime_type")
  storagePath String     @map("storage_path")
  storageUrl  String?    @map("storage_url")
  status      FileStatus @default(UPLOADING)
  checksum    String?
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  page   Page?  @relation(fields: [pageId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([tenantId, pageId])
  @@index([tenantId, userId])
  @@map("file_attachments")
}

// ─── Audit Logs ─────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  // tenantId/userId are NULLABLE (audit S15): a pre-auth / anonymous rejection
  // (401 before any principal is known) must persist a queryable row. Required
  // FKs would FK-violate on a sentinel principal and — because logAuthEvent
  // swallows errors — the row would silently never persist, defeating the audit.
  tenantId   String?  @map("tenant_id")
  userId     String?  @map("user_id")
  apiKeyId   String?  @map("api_key_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations (optional — match the nullable FKs above)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([tenantId, createdAt], map: "idx_audit_logs_tenant_created")
  @@index([userId], map: "idx_audit_logs_user_id")
  @@index([resource, resourceId], map: "idx_audit_logs_resource")
  @@map("audit_logs")
}

// ─── Page Favorites ─────────────────────────────────────────────────

model PageFavorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  pageId    String   @map("page_id")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([userId, pageId], map: "uq_page_favorites_user_page")
  @@index([userId, tenantId], map: "idx_page_favorites_user_tenant")
  @@map("page_favorites")
}

// ─── Page Shares (per-user page permissions) ────────────────────────

model PageShare {
  id         String     @id @default(uuid())
  pageId     String     @map("page_id")
  userId     String     @map("user_id")
  tenantId   String     @map("tenant_id")
  permission Permission @default(CAN_VIEW)
  sharedBy   String     @map("shared_by")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId], map: "uq_page_shares_page_user")
  @@index([userId, tenantId], map: "idx_page_shares_user_tenant")
  @@map("page_shares")
}

// ─── Sweep Sessions (Agent Housekeeping) ───────────────────────────

model SweepSession {
  id          String    @id
  tenantId    String    @map("tenant_id")
  budget      Int
  status      String    @default("RUNNING") // RUNNING | COMPLETED | FAILED | CANCELLED
  results     Json      @default("{}")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([tenantId, startedAt], map: "idx_sweep_sessions_tenant_started")
  @@map("sweep_sessions")
}

// ─── W81-C1: Triage worker state ─────────────────────────────────────
//
// SKB has no durable worker process, so C1 follows the bounded-run convention
// (`scripts/agent-sweep.ts`): each invocation is time/row-budgeted and exits.
// State that must cross runs lives in these tables — NEVER an in-process Map.

// One bounded sweep invocation. Carries the run's stats + the pinned model digest
// so a model change is auditable. NOT a high-water mark itself — the per-pass
// keyset watermarks live in `TriageCursor`.
model TriageRun {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  status      TriageRunStatus @default(RUNNING)
  budget      Int
  // Digest of the Ollama model resolved at run start (null when Ollama was down
  // for the whole run and only deterministic passes ran).
  modelDigest String?         @map("model_digest")
  // Per-pass counters (scanned / findings / deferred / escalated), Ollama status.
  stats       Json            @default("{}")
  startedAt   DateTime        @default(now()) @map("started_at")
  completedAt DateTime?       @map("completed_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, startedAt], map: "idx_triage_runs_tenant_started")
  @@map("triage_runs")
}

// Per-pass keyset watermark `(cursorAt, cursorId)` over the pass's SCANNED anchor
// entity — for STALENESS/CONTRADICTION the claim, for TAGGING the source, for
// DEDUP the page. Embedding passes resume by this anchor keyset, NEVER by pgvector
// similarity order (which has no stable order — GLM R2). Advanced in the SAME
// transaction as the batch's finding writes, so a crash re-does a bounded batch.
model TriageCursor {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  pass      TriagePass
  cursorAt  DateTime?  @map("cursor_at")
  cursorId  String?    @map("cursor_id")
  updatedAt DateTime   @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, pass], map: "uq_triage_cursors_tenant_pass")
  @@map("triage_cursors")
}

// A flagged item. C1's durable output alongside SourceRelevance + the page
// `knowledgeStatus` mark; it NEVER edits a page body. Uniqueness is a PARTIAL
// unique index on `fingerprint WHERE status IN (OPEN,ESCALATED,DEFERRED)`
// (declared in the migration — Prisma can't express filtered uniques), so a
// re-scan can't recreate a live finding yet a recurrence after DISMISS/RESOLVE
// CAN be re-flagged. Pair participants (dedup pages, contradiction claims) are
// stored CANONICALIZED (min,max) in the primary + related columns so (A,B) and
// (B,A) collapse. FKs are onDelete:SetNull (retain display evidence on purge);
// tenant-consistency of every FK is enforced in-transaction (no RLS — the repo's
// per-query isolation convention), not via composite FKs (SetNull can't null the
// NOT NULL tenant_id half of a composite key).
model TriageFinding {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  kind           TriageKind
  status         TriageStatus @default(OPEN)
  // 0..1 — escalation gate compares this to the configured threshold.
  severity       Float        @default(0)
  confidence     Float        @default(0)
  // Primary + related participants (canonicalized min<max for pair kinds).
  pageId         String?      @map("page_id")
  relatedPageId  String?      @map("related_page_id")
  claimId        String?      @map("claim_id")
  relatedClaimId String?      @map("related_claim_id")
  sourceId       String?      @map("source_id")
  // sha256(kind + canonical participants + scopedKey) — dedup identity.
  fingerprint    String
  // Bounded evidence blob (size-capped by the writer), never a page body.
  evidence       Json         @default("{}")
  // The pinned model digest that produced a model-derived finding (null for the
  // deterministic staleness pass).
  modelDigest    String?      @map("model_digest")
  // ── DEFERRED (Ollama-down) bookkeeping ──
  deferReason    String?      @map("defer_reason")
  attempts       Int          @default(0)
  nextAttemptAt  DateTime?    @map("next_attempt_at")
  // ── At-most-once escalation lease (C2 claims via atomic UPDATE ... RETURNING) ──
  escalatedAt    DateTime?    @map("escalated_at")
  leasedAt       DateTime?    @map("leased_at")
  leaseOwner     String?      @map("lease_owner")
  resolvedAt     DateTime?    @map("resolved_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status], map: "idx_triage_findings_tenant_status")
  @@index([tenantId, kind, status], map: "idx_triage_findings_tenant_kind_status")
  @@index([tenantId, status, nextAttemptAt], map: "idx_triage_findings_tenant_defer")
  @@index([status, escalatedAt], map: "idx_triage_findings_escalation")
  @@map("triage_findings")
}

// (b) The source-to-concept tag: which existing concept page a NEW source is
// relevant to, classified by the local model. Upsert-idempotent on
// (tenantId, sourceId, pageId) — a re-run refreshes score/digest, never duplicates.
model SourceRelevance {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  sourceId    String   @map("source_id")
  pageId      String   @map("page_id")
  score       Float    @default(0)
  modelDigest String   @map("model_digest")
  taggedAt    DateTime @default(now()) @map("tagged_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sourceId, pageId], map: "uq_source_relevance_tenant_source_page")
  @@index([tenantId, sourceId], map: "idx_source_relevance_tenant_source")
  @@index([tenantId, pageId], map: "idx_source_relevance_tenant_page")
  @@map("source_relevance")
}

// Durable, idempotent weekly health-check digest (§6). Persists the period key +
// last-success so a re-run in the same period is a no-op (never double-notifies).
model TriageDigest {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  // Period identity, e.g. "2026-W28" (ISO week) — the idempotency key.
  periodKey  String   @map("period_key")
  stats      Json     @default("{}")
  notifiedAt DateTime @default(now()) @map("notified_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, periodKey], map: "uq_triage_digests_tenant_period")
  @@index([tenantId, notifiedAt], map: "idx_triage_digests_tenant_notified")
  @@map("triage_digests")
}

// ─── Google Drive connector (A71-12) ────────────────────────────────

model GoogleDriveConnection {
  id                    String    @id @default(uuid())
  tenantId              String    @map("tenant_id")
  userId                String    @map("user_id")
  encryptedRefreshToken String    @map("encrypted_refresh_token")
  scopes                String[]
  connectedAt           DateTime  @default(now()) @map("connected_at")
  revokedAt             DateTime? @map("revoked_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId], map: "uq_google_drive_connections_tenant_user")
  @@index([tenantId], map: "idx_google_drive_connections_tenant_id")
  @@map("google_drive_connections")
}

model OAuthState {
  id        String   @id @default(uuid())
  state     String   @unique
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt], map: "idx_oauth_states_expires_at")
  @@map("oauth_states")
}

// ─── Anchored-Object Knowledge (AOK-01) ─────────────────────────────
//
// Binds knowledge to a physical object via a QR "anchor" and retrieves it by
// scanning. Deliberately generic (class + JSON attributes) so the same tables
// serve a facility valve, an inventory reagent bottle, or a shipping parcel.
// See docs/stories/2026-07-14-aok-01-anchored-object-backend.md.
//
// ID scheme: all models use Prisma's built-in @default(cuid()) EXCEPT
// AokAnchor, whose id is service-generated with crypto.randomUUID() so the
// derived `payload` can persist in the same single insert as the row.

model AokSite {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  nameKey   String   @map("name_key")
  type      String   @default("other") // lab | residential_block | office | warehouse | other
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spaces AokSpace[]
  assets AokAsset[]

  // Indexes
  @@unique([tenantId, nameKey], map: "uq_aok_sites_tenant_name_key")
  @@index([tenantId], map: "idx_aok_sites_tenant_id")
  @@map("aok_sites")
}

model AokSpace {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  siteId         String   @map("site_id")
  parentId       String?  @map("parent_id")
  kind           String   @default("other") // building | floor | room | zone | shelf | aisle | other
  name           String
  nameKey        String   @map("name_key")
  directionsText String?  @map("directions_text")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site     AokSite    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent   AokSpace?  @relation("AokSpaceHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children AokSpace[] @relation("AokSpaceHierarchy")
  assets   AokAsset[]

  // Indexes — v1 spaces are flat per site (tree fields exist for future use).
  @@unique([tenantId, siteId, nameKey], map: "uq_aok_spaces_tenant_site_name_key")
  @@index([tenantId], map: "idx_aok_spaces_tenant_id")
  @@index([tenantId, siteId], map: "idx_aok_spaces_tenant_site")
  @@index([tenantId, parentId], map: "idx_aok_spaces_tenant_parent")
  @@map("aok_spaces")
}

model AokAsset {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  siteId       String   @map("site_id")
  spaceId      String?  @map("space_id")
  class        String   @default("facility_asset") // facility_asset | inventory_item | parcel
  name         String
  category     String
  criticality  String   @default("low")
  attributes   Json     @default("{}")
  status       String   @default("active") // active | retired | replaced | deleted
  replacedById String?  @map("replaced_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site           AokSite        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  space          AokSpace?      @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  replacedBy     AokAsset?      @relation("AokAssetReplacement", fields: [replacedById], references: [id], onDelete: SetNull)
  replacementFor AokAsset[]     @relation("AokAssetReplacement")
  knowledge      AokKnowledge[]
  anchors        AokAnchor[]
  counts         AokCountLine[]
  visits         AokVisit[]

  // Indexes
  @@index([tenantId], map: "idx_aok_assets_tenant_id")
  @@index([tenantId, siteId], map: "idx_aok_assets_tenant_site")
  @@index([tenantId, spaceId], map: "idx_aok_assets_tenant_space")
  @@index([tenantId, status], map: "idx_aok_assets_tenant_status")
  @@map("aok_assets")
}

model AokAnchor {
  id        String   @id // service-generated via crypto.randomUUID() — see note above
  tenantId  String   @map("tenant_id")
  assetId   String?  @map("asset_id") // null = unbound blank sticker (pre-printable)
  type      String   @default("qr")
  payload   String   @unique // scs://a/<anchorId> — derived from id, globally unique
  status    String   @default("active") // active | retired
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset  AokAsset? @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([tenantId], map: "idx_aok_anchors_tenant_id")
  @@index([tenantId, assetId], map: "idx_aok_anchors_tenant_asset")
  @@map("aok_anchors")
}

model AokKnowledge {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  assetId      String   @map("asset_id")
  kind         String   @default("gotcha") // how_it_works | gotcha | safety_note | location_note | contact
  text         String
  reviewStatus String   @default("approved") @map("review_status") // v1 demo default; AOK-04 flips it
  source       String   @default("voice_capture")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset  AokAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([tenantId], map: "idx_aok_knowledge_tenant_id")
  @@index([tenantId, assetId], map: "idx_aok_knowledge_tenant_asset")
  @@map("aok_knowledge")
}

model AokVisit {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  assetId     String   @map("asset_id")
  reason      String
  outcome     String
  notes       String?
  workerLabel String?  @map("worker_label")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset  AokAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([tenantId], map: "idx_aok_visits_tenant_id")
  @@index([tenantId, assetId], map: "idx_aok_visits_tenant_asset")
  @@map("aok_visits")
}

model AokCountLine {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  assetId     String   @map("asset_id")
  countedQty  Float    @map("counted_qty")
  unit        String?
  expectedQty Float?   @map("expected_qty") // snapshot of attributes.expected_qty at count time
  delta       Float?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset  AokAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([tenantId], map: "idx_aok_count_lines_tenant_id")
  @@index([tenantId, assetId], map: "idx_aok_count_lines_tenant_asset")
  @@map("aok_count_lines")
}
